// vital-ops — schema Prisma (fonte: docs/REQUISITOS.md §4)
// Identificadores de domínio seguem o brief (contrato compartilhado com o frontend).
// Banco: PostgreSQL (Neon em dev/prod — ver DATABASE_URL no .env). Rode
// `npx prisma generate` após editar e `npx prisma migrate dev` para migrar.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Papéis e status
//
// Mantidos como String (sem enum nativo do Postgres) por simplicidade e para
// não acoplar o schema a uma lista fechada de valores — a validação vive no
// zod dos contratos (src/lib/contracts). Role: ADMIN | GESTOR | FUNCIONARIO | FABRICA.
// ImportStatus: RASCUNHO | ENVIANDO | CONCLUIDO | FALHA.
// ProdutoItemStatus: NOVO | DUPLICADO | ERRO | ENVIADO | FALHA.
// EstruturaStatus: PENDENTE | ENVIADO | FALHA.
// RequisicaoStatus: PENDENTE | CONFIRMADA | RECUSADA.
// RequisicaoItemStatus / BaixaItemStatus: PENDENTE | BAIXADO | FALHA.
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Fundação: usuários, setores, auditoria
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         String   @default("FUNCIONARIO")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  setores        UserSetor[]
  auditLogs      AuditLog[]     @relation("AuditActor")
  imports        ProdutoImport[]
  requisicoesFeitas    Requisicao[] @relation("Solicitante")
  requisicoesGeridas   Requisicao[] @relation("Gestor")
  baixas               BaixaImport[] @relation("BaixaAutor")
  reports              Report[]     @relation("ReportAutor")
  reportsResolvidos    Report[]     @relation("ReportResolvedor")

  @@index([role])
}

model Setor {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())

  membros     UserSetor[]
  requisicoes Requisicao[]
}

// Membership N:N entre User e Setor.
model UserSetor {
  userId  String
  setorId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  setor Setor @relation(fields: [setorId], references: [id], onDelete: Cascade)

  @@id([userId, setorId])
  @@index([setorId])
}

// Auditoria em TUDO (REQUISITOS §5). IP real vem de x-forwarded-for na Vercel.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String
  action     String
  entity     String
  entityId   String?
  summary    String
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  omieTarget String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// Reports/feedback dentro do app: o usuário reporta problema/sugestão e vê o
// andamento; erros do sistema são capturados automaticamente (autor nulo). O
// admin trata num modal e marca como resolvido, com resposta que o autor lê.
// tipo: PROBLEMA | SUGESTAO | ERRO_SISTEMA. status: ABERTO | EM_ANALISE | RESOLVIDO.
model Report {
  id             String    @id @default(cuid())
  tipo           String    @default("PROBLEMA")
  titulo         String
  mensagem       String
  status         String    @default("ABERTO")
  autorId        String?
  autorEmail     String?
  rota           String?
  userAgent      String?
  contexto       Json?
  resposta       String?
  resolvidoPorId String?
  resolvidoEm    DateTime?
  criadoEm       DateTime  @default(now())

  autor        User?         @relation("ReportAutor", fields: [autorId], references: [id], onDelete: SetNull)
  resolvidoPor User?         @relation("ReportResolvedor", fields: [resolvidoPorId], references: [id], onDelete: SetNull)
  anexos       ReportAnexo[]

  @@index([status])
  @@index([autorId])
  @@index([criadoEm])
}

// Anexo de um report (print, foto, planilha que deu erro). Guardado no próprio
// banco (bytea) — simples e sem infra extra; limite de tamanho na Server Action
// para caber no serverless. Servido por /api/reports/anexo/[id] com guarda.
model ReportAnexo {
  id       String   @id @default(cuid())
  reportId String
  nome     String
  mime     String
  tamanho  Int
  dados    Bytes
  criadoEm DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

// Permissões configuráveis por papel × módulo (item 3 da sessão de UI/RBAC).
// Chave composta role+module. Módulos válidos: "products" | "pranchas" | "users" | "audit"
// (validados em src/lib/permissions.ts, não aqui — mesmo raciocínio do String
// sem enum explicado acima).
// ADMIN é sempre tratado como true em código (src/lib/permissions.ts), mesmo
// que exista uma linha aqui — trava de segurança, não fica só no seed.
model RolePermission {
  role    String
  module  String
  enabled Boolean @default(true)

  @@id([role, module])
}

// ---------------------------------------------------------------------------
// Módulo Produtos (Fase 2)
// ---------------------------------------------------------------------------

model ProdutoImport {
  id             String   @id @default(cuid())
  autorId        String
  arquivoNome    String
  status         String   @default("RASCUNHO")
  totalProdutos  Int      @default(0)
  totalEstrutura Int      @default(0)
  criadoEm       DateTime @default(now())

  autor     User            @relation(fields: [autorId], references: [id], onDelete: Cascade)
  produtos  ProdutoItem[]
  estrutura EstruturaItem[]

  @@index([autorId])
  @@index([status])
}

model ProdutoItem {
  id                String   @id @default(cuid())
  importId          String
  codigo            String
  descricao         String
  familia           String?
  ncm               String
  unidade           String
  tipo              String
  localEstoque      String?
  controleLote      Boolean  @default(true)
  status            String   @default("NOVO")
  motivoErro        String?
  omieCodigoProduto String?
  enviadoEm         DateTime?

  import ProdutoImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@index([codigo])
}

model EstruturaItem {
  id          String   @id @default(cuid())
  importId    String
  numeroPai   String
  numeroFilho String
  codigoPai   String
  codigoFilho String
  quantidade  Decimal
  status      String   @default("PENDENTE")
  motivoErro  String?

  import ProdutoImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
}

// ---------------------------------------------------------------------------
// Módulo Requisições de fábrica (Fase 3)
//
// Fluxo: o solicitante monta um pedido com VÁRIOS itens (carrinho) → gera um
// número sequencial (autoincrement do Postgres, sem race) → o gestor confirma
// ou recusa o pedido inteiro → na confirmação, cada item vira uma baixa de
// estoque no Omie (IncluirAjusteEstoque, saída no local padrão) e um
// MovimentoEstoque. Falha de um item não desfaz os demais (resultado por item).
// ---------------------------------------------------------------------------

model Requisicao {
  id              String   @id @default(cuid())
  numero          Int      @unique @default(autoincrement())
  solicitanteId   String
  solicitanteNome String
  setorId         String
  observacao      String?
  status          String   @default("PENDENTE")
  gestorId        String?
  motivoDecisao   String?
  // Local de estoque escolhido pelo gestor na confirmação ("0"/null = padrão).
  // Persistido pra retomada após interrupção sair do MESMO local.
  localEstoqueCodigo String?
  localEstoqueNome   String?
  decididaEm      DateTime?
  // Arquivamento: o gestor "some" com um pedido já decidido (confirmado/recusado)
  // pra não poluir as listas. Nada é apagado — arquivadas ficam atrás de um
  // filtro e no relatório. Só decididas podem ser arquivadas.
  arquivada       Boolean  @default(false)
  arquivadaEm     DateTime?
  criadoEm        DateTime @default(now())

  solicitante User  @relation("Solicitante", fields: [solicitanteId], references: [id])
  gestor      User? @relation("Gestor", fields: [gestorId], references: [id], onDelete: SetNull)
  setor       Setor @relation(fields: [setorId], references: [id])

  itens RequisicaoItem[]

  @@index([solicitanteId])
  @@index([setorId])
  @@index([status])
}

model RequisicaoItem {
  id           String   @id @default(cuid())
  requisicaoId String
  sku          String
  descricao    String
  quantidade   Decimal
  status       String   @default("PENDENTE")
  motivoErro   String?
  omieIdProd   String? // codigo_produto (id interno) resolvido na criação
  omieRef      String? // id_ajuste devolvido pelo IncluirAjusteEstoque
  // Local de onde a baixa DESTE item saiu (o gestor pode escolher por item;
  // sem escolha, herda o local do pedido).
  localEstoqueCodigo String?
  localEstoqueNome   String?
  baixadoEm    DateTime?

  requisicao Requisicao         @relation(fields: [requisicaoId], references: [id], onDelete: Cascade)
  movimentos MovimentoEstoque[]

  @@index([requisicaoId])
  @@index([sku])
}

// ---------------------------------------------------------------------------
// Módulo Baixa por planilha (matéria-prima MAT)
//
// O usuário sobe uma planilha (SKU, quantidade, pedido, NF, OP, solicitante),
// a tela valida os códigos e o saldo contra o Omie, e a execução dá baixa
// (saída) item a item no local padrão — pedido/NF/OP viram a observação do
// movimento no Omie (o vínculo nota ↔ pedido pedido pelo Victor).
// ---------------------------------------------------------------------------

model BaixaImport {
  id          String   @id @default(cuid())
  autorId     String
  arquivoNome String
  solicitante String // quem solicitou a entrega (campo da tela)
  // Local de estoque da baixa ("0"/null = padrão) — o "Continuar baixa"
  // retoma no MESMO local da execução original.
  localEstoqueCodigo String?
  localEstoqueNome   String?
  status      String   @default("ENVIANDO")
  totalItens  Int      @default(0)
  criadoEm    DateTime @default(now())

  autor User        @relation("BaixaAutor", fields: [autorId], references: [id], onDelete: Cascade)
  itens BaixaItem[]

  @@index([autorId])
  @@index([status])
}

model BaixaItem {
  id         String   @id @default(cuid())
  importId   String
  sku        String
  descricao  String?
  quantidade Decimal
  pedido     String?
  notaFiscal String?
  op         String?
  status     String   @default("PENDENTE")
  motivoErro String?
  omieIdProd String?
  omieRef    String? // id_ajuste devolvido pelo IncluirAjusteEstoque
  baixadoEm  DateTime?

  import     BaixaImport        @relation(fields: [importId], references: [id], onDelete: Cascade)
  movimentos MovimentoEstoque[]

  @@index([importId])
  @@index([sku])
}

// Trilha dos movimentos de estoque efetivados no Omie (1 linha por baixa que
// DEU CERTO). Aponta pro item de requisição OU pro item de baixa por planilha.
model MovimentoEstoque {
  id               String   @id @default(cuid())
  tipo             String // SAIDA (por ora só baixamos)
  sku              String
  quantidade       Decimal
  omieRef          String?
  requisicaoItemId String?
  baixaItemId      String?
  criadoEm         DateTime @default(now())

  requisicaoItem RequisicaoItem? @relation(fields: [requisicaoItemId], references: [id], onDelete: Cascade)
  baixaItem      BaixaItem?      @relation(fields: [baixaItemId], references: [id], onDelete: Cascade)

  @@index([requisicaoItemId])
  @@index([baixaItemId])
  @@index([sku])
}

// ---------------------------------------------------------------------------
// Cliente Omie — durabilidade importa (REQUISITOS §6, portado do nextstep)
// ---------------------------------------------------------------------------

// Cache de chamadas por (path, call, payload canônico). TTL >= 60s. Guarda
// só respostas ok/vazio (nunca erro). Invalidar = expirar (expiraEm = agora).
model OmieCache {
  chave     String   @id
  path      String
  call      String
  param     Json
  categoria String
  resposta  Json
  criadoEm  DateTime @default(now())
  expiraEm  DateTime

  @@index([path])
  @@index([expiraEm])
}

// Estado compartilhado do circuit breaker — registro único (id = 1).
// `estado` (CLOSED/SOFT/HARD) é observabilidade; a decisão real usa os timestamps.
model OmieBreaker {
  id           Int       @id @default(1)
  estado       String    @default("CLOSED")
  faults       Int       @default(0)
  cooldownUntil DateTime?
  blockedUntil DateTime?
  atualizadoEm DateTime  @updatedAt
}
